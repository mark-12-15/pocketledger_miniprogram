page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.container {
  min-height: 100vh;
  padding: 0 32rpx;
  box-sizing: border-box;
}

/* 通用按钮 */
.btn-primary {
  width: 100%;
  height: 88rpx;
  background: #4F46E5;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-ghost {
  width: 100%;
  height: 88rpx;
  background: transparent;
  color: #4F46E5;
  border: 2rpx solid #4F46E5;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-ghost::after {
  border: none;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}

/* 金额颜色 */
.income { color: #10B981; }
.expense { color: #EF4444; }
