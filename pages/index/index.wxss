/* ── 页面基础 ── */
.ledger-page {
  min-height: 100vh;
  background: #F7F9FC;
}

/* ── 顶部控制区 ── */
.header-area {
  background: #FFFFFF;
  border-radius: 0 0 32rpx 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.02);
  padding: 32rpx 40rpx 56rpx;
}

.period-tabs {
  display: flex;
  background: #F4F6F9;
  border-radius: 32rpx;
  padding: 6rpx;
  width: fit-content;
  margin-bottom: 36rpx;
}

.period-tab {
  padding: 10rpx 40rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #95A5A6;
}

.period-tab.active {
  background: #FFFFFF;
  color: #2C3E50;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}

.date-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
}

.nav-arrow {
  width: 64rpx;
  height: 64rpx;
  background: #F4F6F9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #7F8C8D;
  line-height: 1;
}

.nav-arrow.disabled { opacity: 0.3; }

.date-label {
  font-size: 40rpx;
  font-weight: bold;
  color: #2C3E50;
  min-width: 220rpx;
  text-align: center;
}

/* ── 数据汇总卡片 ── */
.summary-card {
  display: flex;
  background: #FFFFFF;
  border-radius: 32rpx;
  box-shadow: 0 20rpx 40rpx rgba(0,0,0,0.04);
  margin: -20rpx 32rpx 0;
  padding: 32rpx 0;
  position: relative;
  z-index: 10;
}

.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.summary-divider {
  width: 2rpx;
  background: #F0F0F0;
  margin: 4rpx 0;
}

.summary-label {
  font-size: 24rpx;
  color: #95A5A6;
}

.summary-amount {
  font-size: 36rpx;
  font-weight: bold;
}

.summary-amount.income  { color: #07C160; }
.summary-amount.expense { color: #FF6B6B; }
.summary-amount.balance { color: #4A60F6; }

/* ── 账单列表区 ── */
.list-section {
  padding: 32rpx 32rpx 40rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  background: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.04);
}

.empty-icon-text {
  font-size: 56rpx;
  color: #BDC3C7;
  font-weight: bold;
}

.empty-text {
  font-size: 28rpx;
  color: #BDC3C7;
  margin-top: 32rpx;
}

/* 日期分组 */
.day-group { margin-bottom: 28rpx; }

.day-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 8rpx 16rpx;
}

.day-date {
  font-size: 26rpx;
  font-weight: bold;
  color: #7F8C8D;
}

.day-summary {
  font-size: 24rpx;
  color: #BDC3C7;
}

/* 账单卡片 */
.record-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid #F7F9FC;
}

.record-item.last { border-bottom: none; }

.record-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.record-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: #F8F9FA;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.record-icon {
  font-size: 40rpx;
  line-height: 1;
}

.record-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.record-category {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C3E50;
}

.record-note {
  font-size: 24rpx;
  color: #95A5A6;
  max-width: 300rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.record-amount {
  font-size: 32rpx;
  font-weight: bold;
}

.record-amount.income  { color: #07C160; }
.record-amount.expense { color: #FF6B6B; }

.record-parse-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.record-parse-tag.pending { color: #F39C12; background: #FEF9EE; }
.record-parse-tag.confirm { color: #4A60F6; background: #EEF2FF; }

.loading-tip {
  text-align: center;
  padding: 40rpx;
  color: #BDC3C7;
  font-size: 26rpx;
}
