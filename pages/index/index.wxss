.index-page {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 顶部卡片 */
.header-card {
  background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
  padding: 32rpx 40rpx 48rpx;
}

.period-tabs {
  display: flex;
  background: rgba(255,255,255,0.2);
  border-radius: 32rpx;
  padding: 6rpx;
  width: fit-content;
  margin-bottom: 32rpx;
}

.period-tab {
  padding: 10rpx 36rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  transition: all 0.2s;
}

.period-tab.active {
  background: #fff;
  color: #4F46E5;
  font-weight: 600;
}

.date-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  margin-bottom: 40rpx;
}

.nav-arrow {
  width: 56rpx;
  height: 56rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #fff;
  line-height: 1;
}

.nav-arrow.disabled {
  opacity: 0.3;
}

.date-label {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  min-width: 200rpx;
  text-align: center;
}

.summary-row {
  display: flex;
  background: rgba(255,255,255,0.15);
  border-radius: 24rpx;
  padding: 28rpx 0;
}

.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.summary-divider {
  width: 2rpx;
  background: rgba(255,255,255,0.3);
  margin: 8rpx 0;
}

.summary-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.summary-amount {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.summary-amount.income { color: #6EE7B7; }
.summary-amount.expense { color: #FCA5A5; }

/* 列表 */
.list-section {
  padding: 24rpx 32rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  gap: 20rpx;
}

.empty-icon { font-size: 80rpx; }
.empty-text { font-size: 28rpx; color: #999; }

.day-group {
  margin-bottom: 24rpx;
}

.day-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 8rpx 16rpx;
}

.day-date {
  font-size: 26rpx;
  font-weight: 600;
  color: #666;
}

.day-summary {
  font-size: 24rpx;
  color: #999;
}

.record-list {
  padding: 0;
  overflow: hidden;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.record-item.last {
  border-bottom: none;
}

.record-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.record-category-icon {
  font-size: 44rpx;
  width: 72rpx;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 72rpx;
}

.record-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.record-category {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.record-note {
  font-size: 24rpx;
  color: #999;
  max-width: 300rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.record-amount {
  font-size: 32rpx;
  font-weight: 700;
}

.record-amount.income { color: #10B981; }
.record-amount.expense { color: #EF4444; }

.record-parse {
  font-size: 22rpx;
  color: #F59E0B;
  background: #FEF3C7;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.loading-tip {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}
