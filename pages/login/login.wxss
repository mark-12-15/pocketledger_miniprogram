/* ── 整体容器 ── */
.container {
  min-height: 100vh;
  background: #F7F9FC;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  overflow: hidden;
}

/* ── 背景氛围圆 ── */
.bg-blob {
  position: absolute;
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  background: radial-gradient(circle, #E0EAFC, #CFDEF3);
  filter: blur(80px);
  z-index: 0;
}
.bg-blob-tl { top: -160rpx; left: -160rpx; }
.bg-blob-br { bottom: -160rpx; right: -160rpx; }

/* ── 品牌展示区 ── */
.brand-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1;
  padding-top: 80rpx;
}

.logo-box {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: #FFFFFF;
  box-shadow: 0 20rpx 40rpx rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-text {
  font-size: 80rpx;
  font-weight: bold;
  color: #4A60F6;
  line-height: 1;
}

.brand-title {
  font-size: 56rpx;
  font-weight: bold;
  color: #2C3E50;
  margin-top: 48rpx;
}

.brand-subtitle {
  font-size: 28rpx;
  color: #95A5A6;
  margin-top: 20rpx;
  letter-spacing: 2rpx;
}

/* ── 操作区 ── */
.action-area {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 120rpx;
  z-index: 1;
  margin-bottom: 10vh;
}

/* ── 微信登录按钮 ── */
.login-btn {
  width: 600rpx;
  height: 100rpx;
  background: #07C160;
  border-radius: 50rpx;
  box-shadow: 0 16rpx 32rpx rgba(7,193,96,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  border: none;
  padding: 0;
}
.login-btn::after { border: none; }

.wx-icon-dot {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.5);
  flex-shrink: 0;
}

.login-btn-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
}

/* ── 协议 ── */
.terms {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 40rpx;
}
.terms-text {
  font-size: 24rpx;
  color: #BDC3C7;
}
.terms-link {
  font-size: 24rpx;
  color: #4A60F6;
}

/* ── 绑定手机号卡片 ── */
.bind-card {
  margin: 0 40rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 20rpx 40rpx rgba(0,0,0,0.03);
}

.bind-card-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #2C3E50;
  display: block;
}

.bind-card-sub {
  font-size: 24rpx;
  color: #95A5A6;
  display: block;
  margin-top: 12rpx;
}

.form-area {
  margin-top: 40rpx;
}

.bind-input {
  width: 100%;
  height: 88rpx;
  background: #F4F6F9;
  border-radius: 16rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  color: #2C3E50;
  border: none;
}

.bind-placeholder {
  color: #BDC3C7;
  font-size: 28rpx;
}

.code-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 24rpx;
}

.code-row .bind-input {
  flex: 1;
  margin-right: 20rpx;
  width: auto;
}

.btn-send-code {
  width: 220rpx;
  height: 88rpx;
  background: #EEF2FF;
  color: #4A60F6;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  flex-shrink: 0;
  padding: 0;
}
.btn-send-code::after { border: none; }

.submit-btn {
  width: 400rpx;
  height: 88rpx;
  background: #4A60F6;
  color: #FFFFFF;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin: 48rpx auto 0;
  box-shadow: 0 16rpx 32rpx rgba(74,96,246,0.3);
}
.submit-btn::after { border: none; }
