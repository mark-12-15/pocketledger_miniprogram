<view class="container">
  <!-- 背景氛围装饰 -->
  <view class="bg-blob bg-blob-tl"></view>
  <view class="bg-blob bg-blob-br"></view>

  <!-- 品牌展示区 -->
  <view class="brand-area">
    <view class="logo-box">
      <text class="logo-text">账</text>
    </view>
    <text class="brand-title">随手账本</text>
    <text class="brand-subtitle">记录每一笔，掌握每一分</text>
  </view>

  <!-- 操作区 -->
  <view class="action-area">

    <!-- 阶段1：微信登录 -->
    <block wx:if="{{step === 'wx'}}">
      <button
        class="login-btn"
        open-type="{{wxLoginBtnOpenType}}"
        bindgetphonenumber="onGetPhoneNumber"
        bindtap="onWxLogin"
        loading="{{loading}}"
      >
        <view class="wx-icon-dot"></view>
        <text class="login-btn-text">微信一键登录</text>
      </button>
      <view class="terms">
        <text class="terms-text">登录即代表同意</text>
        <text class="terms-link">《用户协议》</text>
        <text class="terms-text">与</text>
        <text class="terms-link">《隐私政策》</text>
      </view>
    </block>

    <!-- 阶段2：绑定手机号 -->
    <block wx:if="{{step === 'phone'}}">
      <view class="phone-card">
        <text class="phone-card-title">绑定手机号</text>
        <text class="phone-card-sub">首次登录需绑定手机号，便于多端同步</text>
        <view class="input-group">
          <input class="input" type="number" maxlength="11" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" placeholder-class="input-placeholder" />
        </view>
        <view class="input-group code-group">
          <input class="input code-input" type="number" maxlength="6" placeholder="验证码" value="{{code}}" bindinput="onCodeInput" placeholder-class="input-placeholder" />
          <button class="btn-send-code" bindtap="onSendCode" disabled="{{codeCooldown > 0}}" loading="{{sendingCode}}">
            {{codeCooldown > 0 ? codeCooldown + 's' : '获取验证码'}}
          </button>
        </view>
        <button class="btn-primary" bindtap="onBindPhone" loading="{{loading}}">完成绑定</button>
      </view>
    </block>

  </view>
</view>
