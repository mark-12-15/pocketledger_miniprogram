<view class="login-page">
  <!-- 未绑定手机号时展示绑定表单，否则展示微信登录 -->
  <view class="login-bg"></view>

  <view class="login-content">
    <view class="logo-area">
      <text class="logo-icon">💰</text>
      <text class="logo-title">随手账本</text>
      <text class="logo-sub">记录每一笔，掌握每一分</text>
    </view>

    <!-- 阶段1：微信登录 -->
    <view class="form-card" wx:if="{{step === 'wx'}}">
      <button class="btn-wx" open-type="{{wxLoginBtnOpenType}}" bindgetphonenumber="onGetPhoneNumber" bindtap="onWxLogin" loading="{{loading}}">
        <text class="btn-wx-icon">微信</text>
        <text>微信一键登录</text>
      </button>
    </view>

    <!-- 阶段2：手动绑定手机号（获取手机号失败时兜底） -->
    <view class="form-card" wx:if="{{step === 'phone'}}">
      <view class="form-title">绑定手机号</view>
      <view class="form-sub">首次登录需绑定手机号，便于多端同步</view>
      <view class="input-group">
        <input class="input" type="number" maxlength="11" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
      </view>
      <view class="input-group code-group">
        <input class="input code-input" type="number" maxlength="6" placeholder="验证码" value="{{code}}" bindinput="onCodeInput" />
        <button class="btn-send-code" bindtap="onSendCode" disabled="{{codeCooldown > 0}}" loading="{{sendingCode}}">
          {{codeCooldown > 0 ? codeCooldown + 's' : '获取验证码'}}
        </button>
      </view>
      <button class="btn-primary" bindtap="onBindPhone" loading="{{loading}}">完成绑定</button>
    </view>
  </view>
</view>
