.add-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 类型切换 */
.type-bar {
  display: flex;
  background: #fff;
  padding: 0 40rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.type-tab {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #999;
  position: relative;
}

.type-tab.active {
  font-weight: 700;
  color: #333;
}

.type-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  border-radius: 3rpx;
}

.type-tab.active.expense::after { background: #EF4444; }
.type-tab.active.income::after { background: #10B981; }

/* 输入方式 */
.input-method-bar {
  display: flex;
  padding: 24rpx 32rpx;
  gap: 16rpx;
  background: #fff;
  margin-bottom: 24rpx;
}

.method-tab {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #666;
  gap: 6rpx;
}

.method-tab.active {
  background: #EEF2FF;
  color: #4F46E5;
  font-weight: 600;
}

/* 表单 */
.form-card {
  background: #fff;
  margin: 0 32rpx 24rpx;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

/* 金额 */
.amount-row {
  display: flex;
  align-items: center;
  padding-bottom: 32rpx;
  border-bottom: 2rpx solid #f0f0f0;
  margin-bottom: 32rpx;
}

.amount-symbol {
  font-size: 48rpx;
  color: #999;
  margin-right: 12rpx;
}

.amount-input {
  flex: 1;
  font-size: 64rpx;
  font-weight: 700;
  color: #1a1a1a;
  height: 80rpx;
  line-height: 80rpx;
}

/* 分类 */
.field-row {
  margin-bottom: 32rpx;
}

.field-label {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 16rpx;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  min-width: 100rpx;
  border: 2rpx solid transparent;
}

.category-item.active {
  background: #EEF2FF;
  border-color: #4F46E5;
}

.category-name {
  font-size: 22rpx;
  color: #666;
}

.category-item.active .category-name {
  color: #4F46E5;
  font-weight: 600;
}

.note-input {
  width: 100%;
  height: 72rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.date-picker {
  height: 72rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  color: #333;
}

/* 上传区域 */
.upload-card {
  min-height: 400rpx;
}

.upload-area {
  min-height: 360rpx;
  border: 3rpx dashed #ddd;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 40rpx;
}

.upload-icon {
  font-size: 80rpx;
  display: block;
  text-align: center;
}

.upload-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.upload-sub {
  font-size: 24rpx;
  color: #999;
}

.preview-image {
  width: 100%;
  max-height: 480rpx;
  border-radius: 12rpx;
}

.file-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.file-icon { font-size: 48rpx; }

.file-name {
  font-size: 28rpx;
  color: #333;
  word-break: break-all;
}

/* 语音 */
.voice-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
  padding: 40rpx 0;
}

.voice-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: #EEF2FF;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: 6rpx solid #C7D2FE;
}

.voice-btn.recording {
  background: #FEE2E2;
  border-color: #FCA5A5;
  transform: scale(1.1);
}

.voice-icon { font-size: 64rpx; }

.voice-tip {
  font-size: 24rpx;
  color: #4F46E5;
  font-weight: 600;
}

.voice-btn.recording .voice-tip {
  color: #EF4444;
}

.voice-sub {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  padding: 0 40rpx;
}

/* 解析状态 */
.parse-status {
  margin-top: 24rpx;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  text-align: center;
}

.parse-status.pending {
  background: #FEF3C7;
  color: #D97706;
}

.parse-status.success {
  background: #D1FAE5;
  color: #059669;
}

.parse-status.error {
  background: #FEE2E2;
  color: #DC2626;
}

/* 提交 */
.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 40rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
}

.btn-submit {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-submit::after { border: none; }
.btn-submit.expense { background: #EF4444; }
.btn-submit.income { background: #10B981; }
