/* ── 页面基础 ── */
.record-page {
  min-height: 100vh;
  background: #F7F9FC;
  padding-bottom: 200rpx;
}

/* ── 本月财务上下文 ── */
.month-context {
  background: #FFFFFF;
  padding: 16rpx 40rpx 0;
  text-align: center;
}

.month-context-text {
  font-size: 24rpx;
  color: #BDC3C7;
}

/* ── 顶部类型 Tab ── */
.type-bar {
  display: flex;
  background: #FFFFFF;
  padding: 0 40rpx;
}

.type-tab {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #95A5A6;
  position: relative;
}

.type-tab.active {
  font-weight: bold;
  color: #2C3E50;
}

.type-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: #4A60F6;
}

/* ── 录入方式 Sub-tab ── */
.method-bar {
  display: flex;
  padding: 20rpx 32rpx;
  gap: 16rpx;
  background: #FFFFFF;
  border-bottom: 2rpx solid #F7F9FC;
}

.method-tab {
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #95A5A6;
  background: transparent;
}

.method-tab.active {
  background: #EEF2FF;
  color: #4A60F6;
  font-weight: bold;
}

/* ── 金额输入卡片 ── */
.amount-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 32rpx;
  margin: 24rpx 32rpx 0;
  padding: 40rpx 40rpx 44rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.03);
}

.amount-symbol {
  font-size: 48rpx;
  color: #2C3E50;
  font-weight: bold;
  margin-right: 12rpx;
  line-height: 1;
}

.amount-input {
  flex: 1;
  font-size: 80rpx;
  font-weight: bold;
  color: #2C3E50;
  height: 96rpx;
  line-height: 96rpx;
}

.amount-placeholder {
  font-size: 80rpx;
  color: #E0E0E0;
}

/* ── 表单卡片 ── */
.form-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  margin: 24rpx 32rpx 0;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.03);
}

.field-label {
  font-size: 26rpx;
  color: #95A5A6;
  display: block;
  margin-bottom: 16rpx;
}

/* ── 分类网格 ── */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.category-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: #F8F9FA;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid transparent;
}

.category-icon-wrap.active {
  background: #EEF2FF;
  border-color: #4A60F6;
}

.category-icon { font-size: 44rpx; line-height: 1; }

.category-name {
  font-size: 24rpx;
  color: #7F8C8D;
}

.category-name.active {
  color: #4A60F6;
  font-weight: bold;
}

/* ── 备注 / 日期输入 ── */
.field-input {
  width: 100%;
  height: 80rpx;
  background: #F4F6F9;
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #2C3E50;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.note-textarea {
  width: 100%;
  min-height: 80rpx;
  background: #F4F6F9;
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
  font-size: 28rpx;
  color: #2C3E50;
  box-sizing: border-box;
  line-height: 1.5;
}

.field-placeholder { color: #BDC3C7; }

.date-picker-val { color: #2C3E50; }

/* ── 上传区域 ── */
.upload-card { min-height: 400rpx; }

.upload-area {
  height: 400rpx;
  background-color: #F8F9FA;
  border: 2rpx dashed #D1D8E0;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  transition: background-color 0.15s, border-color 0.15s;
}

.upload-area:active {
  background-color: #EEF2FF;
  border: 2rpx dashed #4A60F6;
  transform: scale(0.98);
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.upload-icon { font-size: 80rpx; display: block; text-align: center; }
.upload-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #2C3E50;
  margin-top: 20rpx;
}
.upload-sub {
  font-size: 24rpx;
  color: #95A5A6;
  margin-top: 16rpx;
}

/* ── 拍照/相册两按钮 ── */
.upload-actions {
  display: flex;
  height: 400rpx;
}

.upload-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: #F8F9FA;
  border-radius: 24rpx;
}

.upload-btn:active {
  background: #EEF2FF;
}

.upload-btn-icon { font-size: 64rpx; }

.upload-btn-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #2C3E50;
}

.upload-btn-divider {
  width: 2rpx;
  height: 120rpx;
  background: #E8ECF0;
  align-self: center;
  margin: 0 4rpx;
}

/* ── 解析失败重传区域 ── */
.reupload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  gap: 16rpx;
}

.reupload-icon { font-size: 64rpx; }

.reupload-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #E74C3C;
}

.reupload-sub {
  font-size: 24rpx;
  color: #95A5A6;
}

.reupload-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
}

.btn-reupload {
  padding: 18rpx 48rpx;
  background: #4A60F6;
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.btn-manual {
  padding: 18rpx 48rpx;
  background: #F4F6F9;
  color: #7F8C8D;
  border-radius: 48rpx;
  font-size: 28rpx;
}

/* ── 图片预览 ── */
.preview-wrap { width: 100%; }
.preview-image { width: 100%; max-height: 480rpx; border-radius: 12rpx; }

.file-name-row { display: flex; align-items: center; gap: 16rpx; }
.file-icon { font-size: 48rpx; }
.file-name { font-size: 28rpx; color: #2C3E50; word-break: break-all; }

/* ── 语音 ── */
.voice-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
  padding: 40rpx 0;
}

.voice-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: #EEF2FF;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border: 6rpx solid #C7D2FE;
}

.voice-btn.recording {
  background: #FEE2E2;
  border-color: #FCA5A5;
}

.voice-icon { font-size: 64rpx; }

.voice-tip {
  font-size: 24rpx;
  color: #4A60F6;
  font-weight: bold;
}

.voice-btn.recording .voice-tip { color: #FF6B6B; }

.voice-sub {
  font-size: 24rpx;
  color: #95A5A6;
  text-align: center;
  padding: 0 40rpx;
}

/* ── AI 确认表单 ── */
.confirm-banner {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 24rpx 32rpx 0;
  padding: 24rpx 32rpx;
  background: #EEF2FF;
  border-radius: 20rpx;
}

.confirm-banner-icon { font-size: 32rpx; }

.confirm-banner-text {
  font-size: 26rpx;
  color: #4A60F6;
  font-weight: bold;
}

.confirm-type-bar {
  display: flex;
  margin: 24rpx 32rpx 0;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 8rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);
}

.confirm-type-opt {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  font-size: 30rpx;
  color: #95A5A6;
}

.confirm-type-opt.active {
  font-weight: bold;
  color: #FFFFFF;
}

.confirm-type-opt.active.expense { background: #FF6B6B; }
.confirm-type-opt.active.income  { background: #07C160; }

/* ── 非本月日期提示 ── */
.date-warn {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: #FEF9EE;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #E67E22;
  line-height: 1.5;
}

/* ── 解析状态 ── */
.parse-status {
  margin-top: 24rpx;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  text-align: center;
}

.parse-status.pending { background: #FEF9EE; color: #F39C12; }
.parse-status.success { background: #F0FFF4; color: #07C160; }
.parse-status.error   { background: #FFF0F0; color: #FF6B6B; }

/* ── 底部提交按钮（手动录入，fixed） ── */
.submit-area {
  position: fixed;
  bottom: env(safe-area-inset-bottom);
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  padding-bottom: 120rpx;
}

/* ── 确认入账按钮（inline，跟随文档流，避免 fixed 触摸偏移） ── */
.submit-area-inline {
  display: flex;
  justify-content: center;
  padding: 32rpx 32rpx calc(env(safe-area-inset-bottom) + 48rpx);
}

.btn-submit {
  width: 90%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-submit::after { border: none; }

.btn-submit.expense {
  background: #FF6B6B;
  box-shadow: 0 16rpx 32rpx rgba(255,107,107,0.3);
}

.btn-submit.income {
  background: #07C160;
  box-shadow: 0 16rpx 32rpx rgba(7,193,96,0.3);
}
