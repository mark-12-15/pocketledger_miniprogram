<view class="record-page">

  <!-- 本月财务上下文 -->
  <view class="month-context">
    <text class="month-context-text">本月支出 ¥{{monthExpense}}　·　收入 ¥{{monthIncome}}</text>
  </view>

  <!-- 顶部类型 Tab -->
  <view class="type-bar">
    <view class="type-tab {{type === 2 ? 'active' : ''}}" bindtap="setType" data-type="2">支出</view>
    <view class="type-tab {{type === 1 ? 'active' : ''}}" bindtap="setType" data-type="1">收入</view>
  </view>

  <!-- 录入方式 Sub-tab（拍照 > 手动 > 语音 > 文件） -->
  <view class="method-bar">
    <view class="method-tab {{method === 'photo' ? 'active' : ''}}" bindtap="setMethod" data-method="photo">📷 拍照</view>
    <view class="method-tab {{method === 'manual' ? 'active' : ''}}" bindtap="setMethod" data-method="manual">✏️ 手动</view>
    <view class="method-tab {{method === 'voice' ? 'active' : ''}}" bindtap="setMethod" data-method="voice">🎙️ 语音</view>
    <view class="method-tab {{method === 'file' ? 'active' : ''}}" bindtap="setMethod" data-method="file">📄 文件</view>
  </view>

  <!-- 手动输入 -->
  <block wx:if="{{method === 'manual'}}">

    <!-- 金额输入卡片 -->
    <view class="amount-card">
      <text class="amount-symbol">¥</text>
      <input class="amount-input" type="digit" placeholder="0.00" placeholder-class="amount-placeholder"
             value="{{amount}}" bindinput="onAmountInput" focus="{{true}}" />
    </view>

    <!-- 分类网格 -->
    <view class="form-card">
      <text class="field-label">分类</text>
      <view class="category-grid">
        <view wx:for="{{categories}}" wx:key="name"
              class="category-item {{category === item.name ? 'active' : ''}}"
              bindtap="setCategory" data-name="{{item.name}}">
          <view class="category-icon-wrap {{category === item.name ? 'active' : ''}}">
            <text class="category-icon">{{item.icon}}</text>
          </view>
          <text class="category-name {{category === item.name ? 'active' : ''}}">{{item.name}}</text>
        </view>
      </view>

      <!-- 备注 -->
      <text class="field-label" style="margin-top:32rpx;">备注</text>
      <textarea class="note-textarea" placeholder="选填" placeholder-class="field-placeholder"
                value="{{note}}" bindinput="onNoteInput" auto-height maxlength="200" />

      <!-- 日期 -->
      <text class="field-label" style="margin-top:24rpx;">日期</text>
      <picker mode="date" value="{{happenedAt}}" bindchange="onDateChange">
        <view class="field-input date-picker-val">{{happenedAt}} ›</view>
      </picker>
    </view>

  </block>

  <!-- 拍照上传 -->
  <view wx:if="{{method === 'photo' && !showConfirm}}">
    <view class="form-card upload-card">

      <!-- 未选图：显示两个操作按钮 -->
      <view wx:if="{{!uploadFile && parseStatusClass !== 'error'}}" class="upload-actions">
        <view class="upload-btn" bindtap="onTakePhoto">
          <text class="upload-btn-icon">📷</text>
          <text class="upload-btn-text">拍照</text>
        </view>
        <view class="upload-btn-divider"></view>
        <view class="upload-btn" bindtap="onChooseAlbum">
          <text class="upload-btn-icon">🖼️</text>
          <text class="upload-btn-text">从相册选择</text>
        </view>
      </view>

      <!-- 已选图：预览 + 解析中状态 -->
      <view wx:if="{{uploadFile}}" class="preview-wrap">
        <image src="{{uploadFile}}" mode="aspectFit" class="preview-image" />
        <view class="parse-status pending" wx:if="{{parseMessage}}">{{parseMessage}}</view>
      </view>

      <!-- 解析失败：重新上传入口 -->
      <view wx:if="{{parseStatusClass === 'error' && !uploadFile}}" class="reupload-area">
        <text class="reupload-icon">❌</text>
        <text class="reupload-title">解析失败</text>
        <text class="reupload-sub">图片不清晰或内容无法识别</text>
        <view class="reupload-actions">
          <view class="btn-reupload" bindtap="onReupload">重新上传</view>
          <view class="btn-manual" bindtap="setMethod" data-method="manual">手动录入</view>
        </view>
      </view>

      <view class="parse-status {{parseStatusClass}}" wx:if="{{parseMessage && parseStatusClass !== 'error'}}">{{parseMessage}}</view>
    </view>
  </view>

  <!-- AI 解析确认表单 -->
  <block wx:if="{{showConfirm && confirmData}}">
    <view class="confirm-banner">
      <text class="confirm-banner-icon">✨</text>
      <text class="confirm-banner-text">AI 已解析完成，请确认后入账</text>
    </view>

    <!-- 收入/支出切换（可修改） -->
    <view class="confirm-type-bar">
      <view class="confirm-type-opt {{confirmData.type === 2 ? 'active expense' : ''}}"
            bindtap="onConfirmTypeChange" data-type="2">支出</view>
      <view class="confirm-type-opt {{confirmData.type === 1 ? 'active income' : ''}}"
            bindtap="onConfirmTypeChange" data-type="1">收入</view>
    </view>

    <!-- 金额（可修改） -->
    <view class="amount-card">
      <text class="amount-symbol">¥</text>
      <input class="amount-input" type="digit" placeholder="0.00" placeholder-class="amount-placeholder"
             value="{{confirmData.amount}}" bindinput="onConfirmAmountInput" />
    </view>

    <!-- 分类 + 备注 + 日期 -->
    <view class="form-card">
      <text class="field-label">分类</text>
      <view class="category-grid">
        <view wx:for="{{categories}}" wx:key="name"
              class="category-item"
              bindtap="onConfirmCategory" data-name="{{item.name}}">
          <view class="category-icon-wrap {{confirmData.category === item.name ? 'active' : ''}}">
            <text class="category-icon">{{item.icon}}</text>
          </view>
          <text class="category-name {{confirmData.category === item.name ? 'active' : ''}}">{{item.name}}</text>
        </view>
      </view>

      <text class="field-label" style="margin-top:32rpx;">备注</text>
      <textarea class="note-textarea" placeholder="选填" placeholder-class="field-placeholder"
                value="{{confirmData.note}}" bindinput="onConfirmNoteInput" auto-height maxlength="200" />

      <text class="field-label" style="margin-top:24rpx;">日期</text>
      <picker mode="date" value="{{confirmData.happened_at}}" bindchange="onConfirmDateChange">
        <view class="field-input date-picker-val">{{confirmData.happened_at}} ›</view>
      </picker>
    </view>

    <!-- 确认入账按钮 -->
    <view class="submit-area">
      <button class="btn-submit {{confirmData.type === 1 ? 'income' : 'expense'}}"
              bindtap="onConfirmRecord" loading="{{confirming}}">
        确认入账
      </button>
    </view>
  </block>

  <!-- 文件上传（PDF） -->
  <view class="form-card upload-card" wx:if="{{method === 'file'}}">
    <view class="upload-area" bindtap="onChooseFile">
      <view wx:if="{{!uploadFileName}}" class="upload-placeholder">
        <text class="upload-icon">📄</text>
        <text class="upload-text">选择 PDF 文件</text>
        <text class="upload-sub">支持银行账单、发票 PDF</text>
      </view>
      <view wx:if="{{uploadFileName}}" class="file-name-row">
        <text class="file-icon">📄</text>
        <text class="file-name">{{uploadFileName}}</text>
      </view>
    </view>
    <view class="parse-status {{parseStatusClass}}" wx:if="{{parseMessage}}">{{parseMessage}}</view>
  </view>

  <!-- 语音输入 -->
  <view class="form-card upload-card" wx:if="{{method === 'voice'}}">
    <view class="voice-area">
      <view class="voice-btn {{recording ? 'recording' : ''}}"
            bindtouchstart="onVoiceStart" bindtouchend="onVoiceEnd">
        <text class="voice-icon">🎙️</text>
        <text class="voice-tip">{{recording ? '松开结束' : '按住说话'}}</text>
      </view>
      <text class="voice-sub">说出金额和用途，如"午饭花了35块"</text>
    </view>
    <view class="parse-status {{parseStatusClass}}" wx:if="{{parseMessage}}">{{parseMessage}}</view>
  </view>

  <!-- 底部提交按钮 -->
  <view class="submit-area" wx:if="{{method === 'manual'}}">
    <button class="btn-submit {{type === 1 ? 'income' : 'expense'}}"
            bindtap="onSubmit" loading="{{submitting}}">
      记录{{type === 1 ? '收入' : '支出'}}
    </button>
  </view>

</view>
