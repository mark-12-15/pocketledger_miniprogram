.detail-page {
  min-height: 100vh;
  background: #f5f5f5;
}

.amount-header {
  padding: 60rpx 40rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.income-bg { background: linear-gradient(135deg, #059669, #10B981); }
.expense-bg { background: linear-gradient(135deg, #DC2626, #EF4444); }

.amount-label {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}

.amount-value {
  font-size: 72rpx;
  font-weight: 800;
  color: #fff;
}

.detail-card {
  margin: 32rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 16rpx 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.detail-row:last-child { border-bottom: none; }

.detail-key {
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
}

.detail-val {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 500;
  text-align: right;
  max-width: 420rpx;
}

.parse-pending { color: #F59E0B; }

/* 编辑 */
.edit-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.edit-row:last-child { border-bottom: none; }

.field-label {
  font-size: 28rpx;
  color: #999;
  width: 120rpx;
  flex-shrink: 0;
}

.edit-input {
  flex: 1;
  height: 64rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  text-align: right;
}

.date-picker-val {
  font-size: 28rpx;
  color: #1a1a1a;
  text-align: right;
}

.type-switch {
  display: flex;
  gap: 16rpx;
  margin-left: auto;
}

.type-opt {
  padding: 10rpx 28rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #999;
  background: #f5f5f5;
}

.type-opt.active.expense { background: #FEE2E2; color: #DC2626; font-weight: 600; }
.type-opt.active.income { background: #D1FAE5; color: #059669; font-weight: 600; }

/* 操作按钮 */
.action-area {
  padding: 0 32rpx;
}

.btn-edit, .btn-delete, .btn-cancel, .btn-save {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-bottom: 20rpx;
}

.btn-edit::after, .btn-delete::after, .btn-cancel::after, .btn-save::after { border: none; }

.btn-edit { background: #4F46E5; color: #fff; }
.btn-delete { background: #FEE2E2; color: #DC2626; }
.edit-actions { display: flex; gap: 20rpx; }
.btn-cancel { background: #f5f5f5; color: #666; flex: 1; }
.btn-save { background: #4F46E5; color: #fff; flex: 2; }

.loading-page {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  color: #999;
}
